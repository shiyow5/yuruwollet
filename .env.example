# ================================================================
# yuruwollet — 環境変数サンプル。`.env` にコピーして値を埋める。
# 秘密値は Cloudflare Pages/Worker の secret や GitHub secrets に設定する。
# ================================================================

# ---- Supabase (Phase 1〜) ----
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-or-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>          # Go Cron Worker 専用（クライアントに出さない）
# JWT 署名（どちらか一方。新規プロジェクト=ES256, 旧来=HS256）
SUPABASE_SIGNING_KEY=<es256-private-jwk-json>          # Pages Function が Supabase JWT を発行する用
SUPABASE_JWT_SECRET=<legacy-hs256-jwt-secret>

# ---- Cloudflare Access (Phase 2/11) ----
ACCESS_TEAM_DOMAIN=https://<team-name>.cloudflareaccess.com
ACCESS_AUD=<application-audience-tag>

# ---- メンバー写像 (Gmail → member) (Phase 2) ----
EMAIL_YURURI=<yururi-gmail-address>
EMAIL_SHIYOWO=<shiyowo-gmail-address>

# ---- フロント (Vite, VITE_ 接頭辞のみブラウザに露出) ----
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-or-publishable-key>
VITE_API_BASE_URL=/api

# ---- ローカル開発の auth バイパス (本番では未設定) ----
DEV_BYPASS_EMAIL=yururi@example.com

# ---- 為替 API ----
# 既定は keyless の frankfurter.dev のため鍵不要
FX_API_BASE=https://api.frankfurter.dev
