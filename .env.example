# ================================================================
# yuruwollet — 本番セットアップの入力。`.env` にコピーして値を埋める。
#
#   cp .env.example .env
#   （値を埋める）
#   make setup-prod        ← .env を読んで本番構築を自動実行する
#
# .env は gitignore 済み。**このリポジトリは public なので絶対にコミットしない**。
# 取得手順は docs/DEPLOY.md を参照。
# ================================================================

# ================================================================
# 1) Supabase — ダッシュボードで新規プロジェクトを作って控える
#    https://supabase.com/dashboard  (Region: Northeast Asia (Tokyo))
# ================================================================

# Project Settings → General → Reference ID
SUPABASE_PROJECT_REF=

# Project Settings → Database → Database password（プロジェクト作成時に決めたもの）
SUPABASE_DB_PASSWORD=

# https://supabase.com/dashboard/account/tokens で発行する個人アクセストークン
SUPABASE_ACCESS_TOKEN=

# Project Settings → API Keys
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Supabase JWT の署名鍵（どちらか一方だけ埋める）----
#
# このアプリは Pages Function が自前で Supabase JWT を発行するので、**秘密鍵が手元に要る**。
#
# (a) 旧来の HS256: Project Settings → API Keys に「JWT Secret」があればそれを貼る（一番簡単）
SUPABASE_JWT_SECRET=
#
# (b) ES256: JWT Secret が無い新規プロジェクトはこちら。
#     **Supabase から秘密鍵は取り出せない**ので、自分で生成してインポートする:
#       npx supabase gen signing-key --algorithm ES256
#     出力された「秘密鍵 JWK (JSON)」を **1 行にして** ここに貼り、
#     同じ JSON を Supabase ダッシュボードの
#     Project Settings → JWT Keys → Signing Keys → Add standby key → Import で登録し、
#     Rotate して "in use" にする。
SUPABASE_SIGNING_KEY=

# ================================================================
# 2) メンバー（Gmail）
#    Supabase の profiles.email / Pages の env / Access のポリシー の 3 箇所に
#    この値がそのまま使われる（食い違うとログインできない）
# ================================================================
EMAIL_YURURI=
EMAIL_SHIYOWO=

# ================================================================
# 3) Cloudflare
# ================================================================

# ダッシュボード右下の Account ID
CLOUDFLARE_ACCOUNT_ID=

# My Profile → API Tokens → Create Token（Custom token）
# 必要な権限:
#   Account → Cloudflare Pages        → Edit
#   Account → Workers Scripts         → Edit
#   Account → Access: Apps and Policies → Edit
#   Account → Access: Organizations, Identity Providers, and Groups → Edit
#   Zone    → Zone                    → Read   (shiyow.dev)
CLOUDFLARE_API_TOKEN=

# Zero Trust のチーム名（ダッシュボード → Zero Trust → Settings → Custom Pages に出る）
# 例: shiyow  →  team domain は https://shiyow.cloudflareaccess.com になる
CF_TEAM_NAME=

# 公開ホスト名
APP_HOSTNAME=yuruwollet.shiyow.dev

# ================================================================
# 4) Google OAuth（Access のログイン方法）
#    Google Cloud Console → APIs & Services → Credentials
#      → Create OAuth client ID → Web application
#      → Authorized redirect URI に次を入れる:
#         https://<CF_TEAM_NAME>.cloudflareaccess.com/cdn-cgi/access/callback
# ================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ================================================================
# 以下は make setup-prod が自動で導出/設定する。手で埋めなくてよい。
#   SUPABASE_URL       = https://<SUPABASE_PROJECT_REF>.supabase.co
#   VITE_SUPABASE_URL  = 同上
#   VITE_SUPABASE_ANON_KEY = SUPABASE_ANON_KEY
#   ACCESS_TEAM_DOMAIN = https://<CF_TEAM_NAME>.cloudflareaccess.com
#   ACCESS_AUD         = Access アプリ作成時に払い出される AUD タグ
# ================================================================

# ---- ローカル開発専用（本番には絶対に設定しない）----
# Access ヘッダが無いリクエストをこの email として信頼する。
# ACCESS_AUD と ACCESS_TEAM_DOMAIN が両方入っているとコード側で無効化される。
DEV_BYPASS_EMAIL=yururi@example.com
